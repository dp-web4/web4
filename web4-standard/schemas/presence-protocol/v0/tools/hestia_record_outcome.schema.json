{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://web4.io/schemas/presence-protocol/v0/tools/hestia_record_outcome.schema.json",
  "title": "hestia_record_outcome — input + output schemas",
  "description": "Submit the outcome of a previously-begun action. See presence-protocol.md §3.3.",
  "type": "object",
  "properties": {
    "input": { "$ref": "#/$defs/input" },
    "output": { "$ref": "#/$defs/output" }
  },
  "$defs": {
    "input": {
      "type": "object",
      "required": ["action_id", "success"],
      "additionalProperties": true,
      "properties": {
        "action_id": { "type": "string", "format": "uuid" },
        "success": { "type": "boolean" },
        "magnitude": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.5 },
        "error": { "type": ["string", "null"] },
        "result": { "type": ["object", "null"] },
        "session_id": { "type": ["string", "null"], "format": "uuid" }
      }
    },
    "output": {
      "type": "object",
      "required": ["witnessEntryHash", "updatedTrustState"],
      "additionalProperties": false,
      "properties": {
        "witnessEntryHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "updatedTrustState": {
          "$ref": "https://web4.io/schemas/presence-protocol/v0/common/trust_state.schema.json"
        }
      }
    }
  }
}
