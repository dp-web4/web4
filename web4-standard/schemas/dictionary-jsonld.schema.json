{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://web4.io/schemas/dictionary-jsonld.schema.json",
  "title": "Web4 Dictionary Entities — JSON-LD",
  "description": "JSON Schema for Dictionary Entity documents per web4-standard/core-spec/dictionary-entities.md. Validates output from DictionaryEntity.to_jsonld(), DictionarySpec.to_jsonld(), TranslationResult.to_jsonld(), TranslationChain.to_jsonld(), and cross-language implementations.",

  "oneOf": [
    { "$ref": "#/$defs/DictionaryEntity" },
    { "$ref": "#/$defs/DictionarySpec" },
    { "$ref": "#/$defs/TranslationResult" },
    { "$ref": "#/$defs/TranslationChain" }
  ],

  "$defs": {
    "DictionaryType": {
      "type": "string",
      "enum": ["domain", "model", "compression", "meta"],
      "description": "Dictionary type taxonomy (spec §3)."
    },

    "AmbiguityHandling": {
      "type": "string",
      "enum": ["deterministic", "probabilistic", "context_aware", "reject"],
      "description": "How the dictionary resolves ambiguous mappings."
    },

    "ContextRequired": {
      "type": "string",
      "enum": ["none", "minimal", "moderate", "full"],
      "description": "Amount of context required for translation."
    },

    "DomainCoverage": {
      "type": "object",
      "description": "Coverage metrics for a dictionary's domain knowledge.",
      "required": ["terms", "concepts", "relationships"],
      "properties": {
        "terms": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of terms covered."
        },
        "concepts": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of concepts covered."
        },
        "relationships": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of relationships mapped."
        }
      },
      "additionalProperties": false
    },

    "CompressionProfile": {
      "type": "object",
      "description": "How this dictionary compresses meaning (spec §2.2).",
      "required": ["average_ratio", "lossy_threshold", "context_required", "ambiguity_handling"],
      "properties": {
        "average_ratio": {
          "type": "number",
          "minimum": 0,
          "description": "Average compression ratio."
        },
        "lossy_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Threshold for lossy compression."
        },
        "context_required": {
          "$ref": "#/$defs/ContextRequired"
        },
        "ambiguity_handling": {
          "$ref": "#/$defs/AmbiguityHandling"
        }
      },
      "additionalProperties": false
    },

    "DictionarySpec": {
      "type": "object",
      "title": "DictionarySpec",
      "description": "Specification defining a dictionary's scope and capabilities (spec §2.2).",
      "required": [
        "@context",
        "@type",
        "source_domain",
        "target_domain",
        "bidirectional",
        "version",
        "dictionary_type"
      ],
      "properties": {
        "@context": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "minItems": 1,
          "description": "JSON-LD context URIs."
        },
        "@type": {
          "type": "string",
          "const": "DictionarySpec",
          "description": "JSON-LD type identifier."
        },
        "source_domain": {
          "type": "string",
          "minLength": 1,
          "description": "Source domain for translation."
        },
        "target_domain": {
          "type": "string",
          "minLength": 1,
          "description": "Target domain for translation."
        },
        "bidirectional": {
          "type": "boolean",
          "description": "Whether translation works in both directions."
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "description": "Semantic version string."
        },
        "dictionary_type": {
          "$ref": "#/$defs/DictionaryType"
        },
        "coverage": {
          "$ref": "#/$defs/DomainCoverage"
        },
        "compression": {
          "$ref": "#/$defs/CompressionProfile"
        }
      },
      "additionalProperties": false
    },

    "ChainStep": {
      "type": "object",
      "description": "One step in a multi-hop translation chain (spec §4.3).",
      "required": ["step", "source_domain", "target_domain", "dictionary_lct_id", "confidence", "degradation"],
      "properties": {
        "step": {
          "type": "integer",
          "minimum": 1,
          "description": "Step number in the chain."
        },
        "source_domain": {
          "type": "string",
          "minLength": 1
        },
        "target_domain": {
          "type": "string",
          "minLength": 1
        },
        "dictionary_lct_id": {
          "type": "string",
          "minLength": 1,
          "description": "LCT ID of the dictionary performing this step."
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence in this step's translation."
        },
        "degradation": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Semantic loss in this step (1 - confidence)."
        }
      },
      "additionalProperties": false
    },

    "TranslationResult": {
      "type": "object",
      "title": "TranslationResult",
      "description": "Result of a dictionary translation (spec §4.2).",
      "required": [
        "@context",
        "@type",
        "content",
        "confidence",
        "degradation",
        "dictionary_lct_id",
        "witness_required",
        "timestamp"
      ],
      "properties": {
        "@context": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "minItems": 1,
          "description": "JSON-LD context URIs."
        },
        "@type": {
          "type": "string",
          "const": "TranslationResult",
          "description": "JSON-LD type identifier."
        },
        "content": {
          "type": "string",
          "description": "Translated content."
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence in the translation [0,1]."
        },
        "degradation": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Semantic loss (1 - confidence)."
        },
        "dictionary_lct_id": {
          "type": "string",
          "minLength": 1,
          "description": "LCT ID of the translating dictionary."
        },
        "witness_required": {
          "type": "boolean",
          "description": "Whether this translation requires witnessing."
        },
        "witness_lct_ids": {
          "type": "array",
          "items": { "type": "string" },
          "description": "LCT IDs of witnesses."
        },
        "timestamp": {
          "type": "string",
          "description": "ISO 8601 timestamp of the translation."
        }
      },
      "additionalProperties": false
    },

    "TranslationChain": {
      "type": "object",
      "title": "TranslationChain",
      "description": "Multi-hop translation with cumulative degradation tracking (spec §4.3).",
      "required": [
        "@context",
        "@type",
        "steps",
        "cumulative_confidence",
        "cumulative_degradation",
        "length"
      ],
      "properties": {
        "@context": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "minItems": 1,
          "description": "JSON-LD context URIs."
        },
        "@type": {
          "type": "string",
          "const": "TranslationChain",
          "description": "JSON-LD type identifier."
        },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/ChainStep" },
          "description": "Ordered list of translation steps."
        },
        "witness_lct_ids": {
          "type": "array",
          "items": { "type": "string" },
          "description": "LCT IDs of chain-level witnesses."
        },
        "cumulative_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Product of all step confidences."
        },
        "cumulative_degradation": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "1 - cumulative_confidence."
        },
        "length": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of steps in the chain."
        }
      },
      "additionalProperties": false
    },

    "DictionaryEntity": {
      "type": "object",
      "title": "DictionaryEntity",
      "description": "A living semantic bridge with its own LCT and trust profile (spec §2.1).",
      "required": [
        "@context",
        "@type",
        "lct_id",
        "spec",
        "translation_count",
        "successful_translations",
        "success_rate",
        "current_version"
      ],
      "properties": {
        "@context": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "minItems": 1,
          "description": "JSON-LD context URIs."
        },
        "@type": {
          "type": "string",
          "const": "DictionaryEntity",
          "description": "JSON-LD type identifier."
        },
        "lct_id": {
          "type": "string",
          "minLength": 1,
          "description": "LCT identifier for this dictionary."
        },
        "spec": {
          "type": "object",
          "description": "Dictionary specification (inline, without @context/@type).",
          "required": ["source_domain", "target_domain", "bidirectional", "version", "dictionary_type"],
          "properties": {
            "source_domain": { "type": "string", "minLength": 1 },
            "target_domain": { "type": "string", "minLength": 1 },
            "bidirectional": { "type": "boolean" },
            "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
            "dictionary_type": { "$ref": "#/$defs/DictionaryType" },
            "coverage": { "$ref": "#/$defs/DomainCoverage" },
            "compression": { "$ref": "#/$defs/CompressionProfile" }
          },
          "additionalProperties": false
        },
        "translation_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of translations performed."
        },
        "successful_translations": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of successful translations."
        },
        "success_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Translation success rate."
        },
        "current_version": {
          "type": "string",
          "description": "Current dictionary version string."
        }
      },
      "additionalProperties": false
    }
  }
}
