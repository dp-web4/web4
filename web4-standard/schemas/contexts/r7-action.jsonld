    "outcome": { "@id": "web4:outcome", "@type": "xsd:string" },
    "relevance": { "@id": "web4:relevance", "@type": "xsd:decimal" },
    "depth": { "@id": "web4:depth", "@type": "xsd:integer" },
    "relevantEntities": { "@id": "web4:relevantEntities" },
    "lct": { "@id": "web4:lct", "@type": "@id" },
    "attestation": { "@id": "web4:attestation", "@type": "xsd:string" },
    "signature": { "@id": "web4:signature", "@type": "xsd:string" },

    "required": { "@id": "web4:requiredResources" },
    "available": { "@id": "web4:availableResources" },
    "escrow": { "@id": "web4:escrow" },
    "compute": { "@id": "web4:compute" },

    "status": { "@id": "web4:status", "@type": "xsd:string" },
    "output": { "@id": "web4:output" },
    "resourceConsumed": { "@id": "web4:resourceConsumed" },
    "attestations": { "@id": "web4:attestations" },
    "error": { "@id": "web4:error" },

    "subject_lct": { "@id": "web4:subjectLCT", "@type": "@id" },
    "role_lct": { "@id": "web4:roleLCT", "@type": "@id" },
    "action_type": { "@id": "web4:actionType", "@type": "xsd:string" },
    "action_target": { "@id": "web4:actionTarget", "@type": "@id" },
    "rule_triggered": { "@id": "web4:ruleTriggered", "@type": "xsd:string" },
    "reason": { "@id": "web4:reason", "@type": "xsd:string" },
