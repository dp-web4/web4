    "ActionChain": "web4:ActionChain",
    "TensorDelta": "web4:TensorDelta",

    "Rules": "web4:Rules",
    "Role": "web4:Role",
    "Request": "web4:Request",
    "Reference": "web4:Reference",
    "ResourceRequirements": "web4:ResourceRequirements",
    "Result": "web4:Result",

    "action_id": { "@id": "web4:actionId", "@type": "xsd:string" },
    "timestamp": { "@id": "web4:timestamp", "@type": "xsd:dateTime" },
    "prev_action_hash": { "@id": "web4:prevActionHash", "@type": "xsd:string" },

    "rules": { "@id": "web4:rules" },
    "role": { "@id": "web4:role" },
    "request": { "@id": "web4:request" },
