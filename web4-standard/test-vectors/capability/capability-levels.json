        "public_key": "",
        "t3": {"talent": 0.0, "training": 0.0, "temperament": 0.0},
        "v3": {"valuation": 0.0, "veracity": 0.0, "validity": 0.0}
      },
      "expected": {
        "expected_level": 0,
        "trust_tier": "untrusted",
        "is_typical": false
      }
    },
    {
