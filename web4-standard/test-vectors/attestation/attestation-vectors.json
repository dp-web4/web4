        "effective_trust": 0,
        "fresh": false,
        "reason_contains": "Unknown anchor type"
      }
    },
    {
      "id": "ae-verify-software-missing-sig",
      "category": "verification",
      "description": "Software verifier: missing signature → invalid",
      "input": {
        "envelope": {
          "entity_id": "lct://test:no-sig",
          "public_key": "testkey",
          "anchor": {"type": "software"},
          "proof": {
            "format": "ecdsa_software",
            "signature": "",
            "challenge": "nonce-valid"
          },
          "purpose": "session_start"
        }
      },
      "expected": {
        "valid": false,
        "note": "verify_software requires non-empty signature"
      }
    },
    {
      "id": "ae-verify-software-missing-challenge",
      "category": "verification",
      "description": "Software verifier: missing challenge in proof → invalid",
      "input": {
        "envelope": {
          "entity_id": "lct://test:no-challenge-proof",
          "public_key": "testkey",
          "anchor": {"type": "software"},
          "proof": {
            "format": "ecdsa_software",
            "signature": "validSig",
            "challenge": ""
          },
          "purpose": "session_start"
        }
      },
      "expected": {
        "valid": false,
        "note": "verify_software requires non-empty challenge"
      }
    },
    {
      "id": "ae-verify-tpm2-pcr-mismatch",
      "category": "verification",
      "description": "TPM2 verifier: PCR values don't match expected → invalid",
      "input": {
        "envelope": {
          "entity_id": "lct://test:pcr-mismatch",
          "public_key": "testkey",
          "anchor": {"type": "tpm2"},
          "proof": {
            "format": "tpm2_quote",
            "signature": "sigTPM",
            "challenge": "nonce-tpm",
            "pcr_digest": "digest123"
          },
          "platform_state": {
            "available": true,
            "pcr_values": {"0": "aabb1122", "7": "wrongvalue"}
          },
