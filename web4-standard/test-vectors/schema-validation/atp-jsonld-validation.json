    "schema": "../../schemas/atp-jsonld.schema.json",
    "schema_id": "https://web4.io/schemas/atp-jsonld.schema.json",
    "description": "Cross-language validation vectors for ATP/ADP JSON-LD schema. Each 'valid' document MUST pass validation. Each 'invalid' document MUST fail with the indicated error.",
