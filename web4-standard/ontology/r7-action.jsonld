{
  "@context": {
    "web4": "https://web4.io/ontology#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "type": "@type",
    "id": "@id",

    "R7Action": "web4:ActionRecord",
    "ReputationDelta": "web4:ReputationDelta",
    "TensorDelta": "web4:TensorDelta",

    "Rules": "web4:Rules",
    "Role": "web4:Role",
    "Request": "web4:Request",
    "Reference": "web4:Reference",
    "ResourceRequirements": "web4:ResourceRequirements",
    "Result": "web4:Result",

    "actionId": { "@id": "web4:actionId", "@type": "xsd:string" },
    "timestamp": { "@id": "web4:timestamp", "@type": "xsd:dateTime" },
    "prevActionHash": { "@id": "web4:prevActionHash", "@type": "xsd:string" },

    "lawHash": { "@id": "web4:lawHash", "@type": "xsd:string" },
    "society": { "@id": "web4:society", "@type": "@id" },
    "constraints": { "@id": "web4:constraints" },
    "permissions": { "@id": "web4:permissions" },
    "prohibitions": { "@id": "web4:prohibitions" },

    "actor": { "@id": "web4:actor", "@type": "@id" },
    "roleLCT": { "@id": "web4:roleLCT", "@type": "@id" },
    "pairedAt": { "@id": "web4:pairedAt", "@type": "xsd:dateTime" },
    "t3InRole": { "@id": "web4:hasT3Tensor" },
    "v3InRole": { "@id": "web4:hasV3Tensor" },

    "action": { "@id": "web4:actionType", "@type": "xsd:string" },
    "target": { "@id": "web4:resource", "@type": "@id" },
    "parameters": { "@id": "web4:parameters" },
    "atpStake": { "@id": "web4:atpStake", "@type": "xsd:decimal" },
    "nonce": { "@id": "web4:nonce", "@type": "xsd:string" },

    "precedents": { "@id": "web4:precedents" },
    "mrhContext": { "@id": "web4:mrhContext" },
    "witnesses": { "@id": "web4:witnesses" },

    "required": { "@id": "web4:requiredResources" },
    "available": { "@id": "web4:availableResources" },
    "escrow": { "@id": "web4:escrow" },

    "status": { "@id": "web4:status", "@type": "xsd:string" },
    "output": { "@id": "web4:output" },
    "resourceConsumed": { "@id": "web4:resourceConsumed" },
    "attestations": { "@id": "web4:attestations" },

    "subjectLCT": { "@id": "web4:subjectLCT", "@type": "@id" },
    "actionTarget": { "@id": "web4:actionTarget", "@type": "@id" },
    "ruleTriggered": { "@id": "web4:ruleTriggered", "@type": "xsd:string" },
    "reason": { "@id": "web4:reason", "@type": "xsd:string" },
    "t3Delta": { "@id": "web4:t3Delta" },
    "v3Delta": { "@id": "web4:v3Delta" },
    "contributingFactors": { "@id": "web4:contributingFactors" },
    "netTrustChange": { "@id": "web4:netTrustChange", "@type": "xsd:decimal" },
    "netValueChange": { "@id": "web4:netValueChange", "@type": "xsd:decimal" },

    "change": { "@id": "web4:change", "@type": "xsd:decimal" },
    "from": { "@id": "web4:fromValue", "@type": "xsd:decimal" },
    "to": { "@id": "web4:toValue", "@type": "xsd:decimal" },
    "factor": { "@id": "web4:factor", "@type": "xsd:string" },
    "weight": { "@id": "web4:weight", "@type": "xsd:decimal" }
  }
}
