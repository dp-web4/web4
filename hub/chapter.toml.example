# AIC Hub — chapter configuration example.
#
# A real chapter.toml is generated by `hub init` and lives at
# <chapter-dir>/config.toml. This file is a reference for what fields exist
# and what they mean — you should not edit it directly in a deployed
# chapter; use `hub init` to bootstrap, then edit config.toml in place if
# you need to change a setting (e.g., MCP port).

[chapter]
# Human-readable chapter name. Shown in `hub status`, MCP responses, etc.
# Set by the `name` argument to `hub init`.
name = "Lisbon Chapter"

[daemon]
# Port the MCP HTTP server binds to. Default 8770. Override with
# `hub serve --port <N>` at runtime if needed.
mcp_port = 8770

[sovereign]
# Path to the Sovereign LCT file. Absolute path recommended; `hub init`
# canonicalizes whatever path was passed via --sovereign-lct.
#
# This file contains the Sovereign's private key material. Protect it:
#   chmod 600 sovereign.json
#   keep it OUTSIDE the chapter dir (don't commit it to version control)
lct_path = "/path/to/sovereign.json"
